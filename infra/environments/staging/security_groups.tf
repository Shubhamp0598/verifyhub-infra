resource "aws_security_group" "api_gateway" {
  name_prefix = "${var.project_name}-${var.environment}-api-gateway-"
  vpc_id      = module.networking.vpc_id

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

